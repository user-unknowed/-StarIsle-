# 星屿项目环境变量配置模板
# 生产环境请替换为真实值

# 应用环境
ENVIRONMENT=development

# PostgreSQL数据库
DATABASE_URL=postgresql://starisle_user:password123@localhost:5432/starisle
DB_PASSWORD=password123

# MongoDB数据库
MONGODB_URL=mongodb://starisle_admin:password123@localhost:27017/starisle
MONGO_PASSWORD=password123

# Redis缓存
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password123

# JWT认证
JWT_SECRET=starisle_jwt_secret_key_2026

# 加密密钥
ENCRYPTION_KEY=starisle_encryption_key_2026

# Kafka消息队列
KAFKA_BROKER=localhost:9092

# AI模型配置
MODEL_NAME=deepseek-ai/deepseek-chat
MODEL_API_KEY=your_api_key_here
MODEL_API_BASE=https://api.deepseek.com
USE_LOCAL_MODEL=false

# 语义分析配置
SEMANTIC_CONFIDENCE_THRESHOLD=0.7

# API配置
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000

# 速率限制
RATE_LIMIT_RPS=100

# 推送服务（可选）
PUSH_SERVICE_URL=http://localhost:9000

# 日志配置
LOG_LEVEL=info

# 安全配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
TLS_ENABLED=false